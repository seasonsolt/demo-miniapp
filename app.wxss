page {
  min-height: 100vh;
  background: #f7f8fa;
  color: #333333;
  font-size: 28rpx;
}

.page {
  padding: 32rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.title {
  margin-bottom: 16rpx;
  font-size: 36rpx;
  font-weight: 600;
}

.muted {
  color: #666666;
  line-height: 1.5;
}

.primary-button {
  margin-top: 24rpx;
  border-radius: 44rpx;
  background: #ff6b35;
  color: #ffffff;
}

.status {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  word-break: break-all;
}

.status-success {
  background: #e8f5e9;
  color: #1b5e20;
}

.status-error {
  background: #ffebee;
  color: #b71c1c;
}
